# Python environments
.venv/

# Python bytecode/cache
__pycache__/
*.py[cod]
*$py.class

# Python packaging/build artifacts
*.egg-info/
.eggs/
build/
dist/

# Test/lint/type-check caches
.pytest_cache/
.ruff_cache/
.ty/
.coverage
.coverage.*
htmlcov/
coverage/
*.profraw

# Rust
target/

# Compiled extension artifacts that may appear locally
*.so
*.pyd
*.dylib
*.dll

# macOS
.DS_Store

# agents
.claude
.codex

# local planning notes and design specs, never committed
.NOTES/
docs/superpowers/

# Benchmarks: generated fixtures and pytest-benchmark saved results
benchmarks/.cache/
.benchmarks/

# Local reference datasets: multi-hundred-MB sources sliced into tests/data
# fixtures and used as benchmark targets. Never committed. Anchored to the repo
# root so it does not also ignore the committed tests/data fixtures.
/data/
